<%- include('partials/header') %>

<div class="container py-5">

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">

<h2 class="text-light">
Welcome <span class="text-info"><%= user.username %></span>
</h2>

<form action="/logout" method="POST">
<button class="btn btn-outline-info">
Logout
</button>
</form>

</div>


<!-- CARD -->
<div class="card bg-dark border-0 p-4 mb-4 shadow">

<h4 class="mb-4 text-info">
Algorithm Pattern Skills
</h4>

<% Object.keys(user.topicPerformance).forEach(topic => { 

const data = user.topicPerformance[topic];

const percent = data.total === 0 
  ? 0 
  : Math.floor((data.correct / data.total) * 100);

%>

<div class="mb-4">

<!-- LABEL + PERCENT -->
<div class="d-flex justify-content-between text-light mb-1">

<span class="fw-semibold">
<%= topic %>
</span>

<span class="text-info fw-bold">
<%= percent %>%
</span>

</div>

<!-- PROGRESS BAR -->
<div class="progress bg-secondary rounded-pill" style="height: 10px;">

<div 
class="progress-bar bg-info progress-bar-striped progress-bar-animated"
style="width: <%= percent %>%">
</div>

</div>

</div>

<% }) %>

</div>


<!-- CTA -->
<div class="text-center">

<form action="/start-test" method="POST">
    
<button class="btn btn-lg btn-info px-5 fw-bold shadow">
Start Adaptive Test
</button>

</form>

</div>

</div>

<%- include('partials/footer') %>