<%- include('partials/header') %>

<div class="auth-wrapper">

  <div class="auth-card">

    <div class="logo">APT</div>

    <h2 class="title">
      Adaptive Pattern Trainer
    </h2>

    <p class="subtitle">
      Train algorithmic pattern recognition.
    </p>

    <form method="POST" action="/login">

      <input
        type="text"
        name="username"
        placeholder="Username"
        class="input"
        required
      />

      <input
        type="password"
        name="password"
        placeholder="Password"
        class="input"
        required
      />

      <button class="btn-primary">
        Login
      </button>

    </form>

    <p class="switch">
      New user?
      <a href="/register">Create account</a>
    </p>

  </div>

</div>

<%- include('partials/footer') %>